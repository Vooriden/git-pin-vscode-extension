{
  "name": "git-pin",
  "displayName": "Git Pin",
  "description": "Pin your favorite Git branches and stashes for quick access",
  "version": "0.2.8",
  "icon": "assets/icon/icon.png",
  "publisher": "vooriden",
  "repository": {
    "url": "https://github.com/Vooriden/git-pin-vscode-extension"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "SCM Providers"
  ],
  "keywords": [
    "git",
    "branch",
    "stash",
    "scm",
    "source-control",
    "productivity",
    "pinned"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "git-pin.pinCurrentBranch",
        "title": "Git Pin: Pin Current Branch",
        "icon": {
          "light": "media/octicons/light/pin-16.svg",
          "dark": "media/octicons/dark/pin-16.svg"
        }
      },
      {
        "command": "git-pin.pinBranchFromList",
        "title": "Git Pin: Pin Branch",
        "icon": {
          "light": "media/octicons/light/plus-16.svg",
          "dark": "media/octicons/dark/plus-16.svg"
        }
      },
      {
        "command": "git-pin.unpinBranch",
        "title": "Git Pin: Unpin Branch",
        "icon": {
          "light": "media/octicons/light/pin-slash-16.svg",
          "dark": "media/octicons/dark/pin-slash-16.svg"
        }
      },
      {
        "command": "git-pin.refresh",
        "title": "Git Pin: Refresh Pinned Items",
        "icon": {
          "light": "media/octicons/light/sync-16.svg",
          "dark": "media/octicons/dark/sync-16.svg"
        }
      },
      {
        "command": "git-pin.pinStash",
        "title": "Git Pin: Pin Stash",
        "icon": {
          "light": "media/octicons/light/plus-16.svg",
          "dark": "media/octicons/dark/plus-16.svg"
        }
      },
      {
        "command": "git-pin.unpinStash",
        "title": "Git Pin: Unpin Stash",
        "icon": {
          "light": "media/octicons/light/pin-slash-16.svg",
          "dark": "media/octicons/dark/pin-slash-16.svg"
        }
      },
      {
        "command": "git-pin.applyStash",
        "title": "Git Pin: Apply Stash",
        "icon": {
          "light": "media/octicons/light/package-dependents-16.svg",
          "dark": "media/octicons/dark/package-dependents-16.svg"
        }
      },
      {
        "command": "git-pin.popStash",
        "title": "Git Pin: Pop Stash",
        "icon": {
          "light": "media/octicons/light/upload-16.svg",
          "dark": "media/octicons/dark/upload-16.svg"
        }
      }
    ],
    "views": {
      "scm": [
        {
          "id": "pinnedItems",
          "name": "Pinned",
          "icon": "media/pinned-view.svg"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "git-pin.refresh",
          "when": "view == pinnedItems",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "git-pin.pinBranchFromList",
          "when": "view == pinnedItems && viewItem == pinnedSectionBranches",
          "group": "inline"
        },
        {
          "command": "git-pin.pinStash",
          "when": "view == pinnedItems && viewItem == pinnedSectionStashes",
          "group": "inline"
        },
        {
          "command": "git-pin.unpinBranch",
          "when": "view == pinnedItems && viewItem == pinnedBranch",
          "group": "inline"
        },
        {
          "command": "git-pin.applyStash",
          "when": "view == pinnedItems && viewItem == pinnedStash",
          "group": "inline"
        },
        {
          "command": "git-pin.popStash",
          "when": "view == pinnedItems && viewItem == pinnedStash",
          "group": "inline"
        },
        {
          "command": "git-pin.unpinStash",
          "when": "view == pinnedItems && viewItem == pinnedStash",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "typescript": "^5.1.6"
  }
}
